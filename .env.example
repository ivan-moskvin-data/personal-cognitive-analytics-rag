# ============================================
# PCAR: Personal Cognitive Analytics RAG
# Шаблон конфигурации окружения
# ============================================
# Скопируйте этот файл в .env и заполните значениями
# НЕ коммитьте .env в репозиторий!
# ============================================

# OpenRouter API Key (обязательно)
# Получите ключ на https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Анонимная телеметрия (опционально)
# Установите True для отправки анонимных метрик использования
# Установите False для полной приватности
ANONYMIZED_TELEMETRY=False
